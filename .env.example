# 개발 환경 설정 (.env.development)
VITE_USE_EMULATOR=true
VITE_USE_MOCK=false
VITE_FIREBASE_PROJECT_ID=your_project_id

# Firebase 에뮬레이터 포트 (로컬)
VITE_FIREBASE_AUTH_EMULATOR_PORT=9099
VITE_FIREBASE_FIRESTORE_EMULATOR_PORT=8181

# Analytics (개발용 - 선택사항)
VITE_GA4_MEASUREMENT_ID=
VITE_SMARTLOOK_KEY=
VITE_SEGMENT_WRITE_KEY=

# Paddle (개발용 - Sandbox)
VITE_PADDLE_CLIENT_TOKEN=ctk_live_xxx
PADDLE_API_KEY=pdl_test_xxx

---

# 프로덕션 환경 설정 (.env.production)
VITE_USE_EMULATOR=false
VITE_USE_MOCK=false

# Firebase 설정 (프로덕션)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Analytics (프로덕션)
VITE_GA4_MEASUREMENT_ID=your_ga4_id
VITE_SMARTLOOK_KEY=your_smartlook_key
VITE_SEGMENT_WRITE_KEY=your_segment_key

# Paddle (프로덕션)
VITE_PADDLE_CLIENT_TOKEN=ctk_live_xxx
PADDLE_API_KEY=pdl_live_xxx
