# Paddle API 설정
# Paddle Dashboard > Developer Settings > API Keys에서 발급
# Sandbox 환경에서 테스트할 때 사용

# Sandbox API Key (테스트용)
PADDLE_API_KEY=test_key_here_for_development

# Production API Key (배포 시)
# PADDLE_PRODUCTION_API_KEY=live_key_here_for_production

# Firebase Webhook Secret (향후 사용)
# PADDLE_WEBHOOK_SECRET=your_webhook_secret_here
