{
  "name": "wedding-prism-studio",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "npm run dev",
    "dev:emulator": "concurrently \"firebase emulators:start --import=./firebase-data --export-on-exit=./firebase-data\" \"npm run dev:with-emulator\"",
    "dev:with-emulator": "sleep 3 && VITE_USE_EMULATOR=true vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:all": "npm run build && firebase deploy",
    "deploy:functions": "firebase deploy --only functions",
    "seed": "node functions/src/seed.js",
    "emulators": "firebase emulators:start",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "paddle:test": "node scripts/test-paddle.js"
  },
  "dependencies": {
    "@paddle/paddle-node-sdk": "^3.6.0",
    "@react-oauth/google": "^0.13.4",
    "dotenv": "^17.3.1",
    "firebase": "^12.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "vite": "^5.0.8"
  }
}
