# ========================================
# Prism Studio Wedding - Local Development Template
# ========================================
# 신규 개발자: 이 파일을 참고해서 .env.local 생성
# cp .env .env.local 후 실제 값 입력

# Firebase 에뮬레이터
VITE_USE_EMULATOR=true
VITE_FIREBASE_PROJECT_ID=prism-wedding-84b5d

# Firebase 설정 (실제 키는 .env.local에만)
VITE_FIREBASE_API_KEY=dummy-api-key
VITE_FIREBASE_AUTH_DOMAIN=prism-wedding-84b5d.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=prism-wedding-84b5d.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:dummy

# Google OAuth
# VITE_GOOGLE_CLIENT_ID=your_google_client_id

# 개발 플래그
VITE_ENABLE_DEV_LOGIN=true
VITE_DEV_TEST_EMAIL=test@prism.com
VITE_DEV_TEST_PASSWORD=testPassword123

# Paddle Sandbox
# VITE_PADDLE_CLIENT_TOKEN=ctk_live_xxx
# PADDLE_API_KEY=pdl_test_xxx
