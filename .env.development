# 개발 서버 (npm run dev) - Mock 서비스 사용
VITE_USE_MOCK=true

# Firebase 설정 (개발 환경에서는 Mock 사용, 필요시 아래에 실제 값 입력)
# Firebase Console: https://console.firebase.google.com/project/prism-wedding-84b5d/settings/general
VITE_FIREBASE_API_KEY=mock-api-key
VITE_FIREBASE_AUTH_DOMAIN=mock-auth-domain
VITE_FIREBASE_PROJECT_ID=prism-wedding-84b5d
VITE_FIREBASE_STORAGE_BUCKET=mock-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=mock-messaging-sender-id
VITE_FIREBASE_APP_ID=mock-app-id
